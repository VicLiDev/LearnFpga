# 02_advanced_constraints.xdc
# 进阶时序约束
#
# 涵盖: 多时钟域、异步 FIFO、多周期路径、虚拟时钟

#=============================================================================================
# 1. 多时钟域
#=============================================================================================

# 主时钟: 100MHz
create_clock -period 10.000 -name clk_100m [get_ports clk_main]

# 外部时钟: 25MHz (来自外设)
create_clock -period 40.000 -name clk_25m [get_ports clk_ext]

# PLL 产生的 200MHz 派生时钟
create_generated_clock -name clk_200m \
    -source [get_pins clk_wiz/clk_in1] \
    -divide_by 1 \
    [get_pins clk_wiz/clk_out1]

#=============================================================================================
# 2. 跨时钟域虚假路径
#=============================================================================================

# 异步 FIFO 的写指针同步到读时钟域 — 不做时序分析
# set_false_path -from [get_pins -hierarchical -filter {NAME =~ "*wr_ptr*"}] \
#                 -to   [get_pins -hierarchical -filter {NAME =~ "*sync2*"}]

# 通用: 从时钟域 A 到时钟域 B 的所有路径设为虚假路径
# set_clock_groups -asynchronous \
#     -group [get_clocks -include_generated_clocks clk_100m] \
#     -group [get_clocks -include_generated_clocks clk_25m]

#=============================================================================================
# 3. 多周期路径
#=============================================================================================

# 多周期路径: 允许数据在 N 个时钟周期内到达
# 应用: 慢速外设接口, 或者流水线中间级

# 示例: 从 reg_a 到 reg_b 的路径需要 2 个时钟周期
# -setup: 默认检查 1 个周期, 改为 2 个
# -hold: 需要相应调整 (通常为 N-1=1)
# set_multicycle_path 2 -setup -from [get_pins reg_a/Q] -to [get_pins reg_b/D]
# set_multicycle_path 1 -hold  -from [get_pins reg_a/Q] -to [get_pins reg_b/D]

#=============================================================================================
# 4. 最大延迟约束 (用于组合逻辑路径)
#=============================================================================================

# 异步信号通过 2 级同步器后, 限制最大延迟不超过 N ns
# set_max_delay -from [get_ports async_signal] \
#               -to   [get_pins sync_stage2/D] \
#               15.000

#=============================================================================================
# 5. 最小延迟约束 (防止保持时间违例)
#=============================================================================================

# set_min_delay -from [get_pins src_reg/Q] \
#               -to   [get_pins dst_reg/D] \
#               1.000

#=============================================================================================
# 6. 虚拟时钟 (用于 IO 约束中无实际时钟的情况)
#=============================================================================================

# 当 IO 引脚的时钟不来自 FPGA 内部时, 需要创建虚拟时钟
# create_clock -period 8.000 -name virt_clk

# 用虚拟时钟约束输入延迟
# set_input_delay -clock virt_clk -max 2.0 [get_ports ext_data]
